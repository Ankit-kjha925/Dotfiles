# tmux prefix passthrough
keybind = cmd+b=text:\x01

# tmux session switcher
keybind = cmd+s=text:\x01\x73

# toggle pane zoom
keybind = cmd+enter=text:\x01\x7a

# aesthetics
background-opacity = 0.75
background-blur=15
background=#000000
macos-titlebar-style=hidden
theme = TokyoNight

# typography
font-family = JetBrainsMono Nerd Font
font-size=16
font-thicken=true
adjust-cell-height=1

# ghostty functions
confirm-close-surface=false

# keybinds
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+w=close_window
